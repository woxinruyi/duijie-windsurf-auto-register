# Windsurf 目标站点
WINDSURF_BASE_URL=https://windsurf.com

# WindsurfPoolAPI
WINDSURF_POOL_URL=http://你的ip:3003
WINDSURF_POOL_UPLOAD_MODE=auth
WINDSURF_POOL_DASHBOARD_PASSWORD=你的面板密码
WINDSURF_POOL_SSH_KEY_PATH=~/.ssh/id_ed25519
WINDSURF_POOL_SSH_USER=root
WINDSURF_POOL_LABEL=

# YYDS Mail
YYDS_MAIL_BASE_URL=https://maliapi.215.im/v1
YYDS_MAIL_API_KEY=你的apikey
YYDS_MAIL_DOMAIN=
YYDS_MAIL_SUBDOMAIN=
YYDS_MAIL_LOCAL_PART=

# 注册信息
WINDSURF_NAME=
WINDSURF_PASSWORD=
WINDSURF_OTT=
WINDSURF_WORKFLOW_MODE=full

# 请求与轮询
REQUEST_TIMEOUT=20
POLL_TIMEOUT=180
POLL_INTERVAL=5
MAX_ATTEMPTS=5
VERIFY_SSL=true
DEBUG=false
SHOW_SECRETS=false
OUTPUT_JSON=
